{
    "name"              : "jbzoo/ci-report-converter",
    "type"              : "library",
    "license"           : "MIT",
    "description"       : "The tool converts different error reporting standards for deep integration with popular CI systems (TeamCity, IntelliJ IDEA, GitHub Actions, etc)",
    "keywords"          : [
        "checkstyle",
        "codestyle",
        "phpstorm",
        "teamcity",
        "github",
        "github actions",
        "actions",
        "junit",
        "pmd",
        "phpmd",
        "phpmnd",
        "psalm",
        "phpstan",
        "phan",
        "phpcs",
        "phpmd",
        "phploc",
        "teamcity-inspections",
        "inspections",
        "tests",
        "ci",
        "continuous integration",
        "IntelliJ IDEA"
    ],

    "authors"           : [
        {
            "name"  : "Denis Smetannikov",
            "email" : "admin@jbzoo.com",
            "role"  : "lead"
        }
    ],

    "minimum-stability" : "dev",
    "prefer-stable"     : true,

    "require"           : {
        "php"             : "^8.3",
        "ext-dom"         : "*",
        "ext-simplexml"   : "*",
        "ext-hash"        : "*",

        "jbzoo/data"      : "^8.0",
        "jbzoo/utils"     : "^8.0",
        "jbzoo/cli"       : "^8.0",
        "jbzoo/markdown"  : "^8.0",

        "symfony/console" : ">=7.3.4"
    },

    "require-dev"       : {
        "jbzoo/toolbox-dev"         : "^8.0",
        "jbzoo/mermaid-php"         : "^8.0",
        "roave/security-advisories" : "dev-master"
    },

    "bin"               : ["ci-report-converter"],

    "autoload"          : {
        "psr-4" : {"JBZoo\\CIReportConverter\\" : "src"}
    },

    "autoload-dev"      : {
        "psr-4" : {"JBZoo\\PHPUnit\\" : "tests"}
    },

    "config"            : {
        "optimize-autoloader" : true,
        "allow-plugins"       : {"composer/package-versions-deprecated" : true},
        "platform-check"      : true
    },

    "extra"             : {
        "branch-alias" : {
            "dev-master" : "8.x-dev"
        }
    }
}
